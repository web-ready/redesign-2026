{
  "cleanUrls": true,
  "outputDirectory": "public",
  "redirects": [
    { "source": "/mittler-senior-technology",   "destination": "/case-studies/mittler-senior-technology",   "permanent": true },
    { "source": "/denman-place-mall",           "destination": "/case-studies/denman-place-mall",           "permanent": true },
    { "source": "/breathwave",                  "destination": "/case-studies/breathwave",                  "permanent": true },
    { "source": "/oasis-of-change-website",     "destination": "/case-studies/oasis-of-change-website",     "permanent": true },

    { "source": "/web-ready",                   "destination": "/initiatives/web-ready",                    "permanent": true },
    { "source": "/vcasse",                      "destination": "/initiatives/vcasse",                       "permanent": true },
    { "source": "/wra_platform",                "destination": "/initiatives/wra-platform",                 "permanent": true },
    { "source": "/sustainable-technology-week", "destination": "/initiatives/sustainable-technology-week",  "permanent": true },

    { "source": "/tree_planting",               "destination": "/tree-planting",                            "permanent": true },
    { "source": "/accessibility_statement",     "destination": "/accessibility-statement",                  "permanent": true },
    { "source": "/sustainability_statement",    "destination": "/sustainability-statement",                 "permanent": true },
    { "source": "/get_involved",                "destination": "/get-involved",                             "permanent": true },
    { "source": "/news_release",                "destination": "/news",                                     "permanent": true },
    { "source": "/annual_reports",              "destination": "/annual-report",                            "permanent": true },
    { "source": "/annual_report_2024_2025",     "destination": "/annual-report/2024-2025",                  "permanent": true },
    { "source": "/annual_report_2025_2026",     "destination": "/annual-report/2025-2026",                  "permanent": true },
    { "source": "/example_annual_report",       "destination": "/example-annual-report",                    "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://translate.google.com https://translate.googleapis.com https://www.gstatic.com https://www.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://www.gstatic.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://translate.googleapis.com https://translate.google.com; frame-src 'self' https://www.youtube-nocookie.com https://www.youtube.com https://translate.googleapis.com https://www.google.com; media-src 'self' https://www.youtube-nocookie.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
